@PACKAGE_INIT@

if(NOT DEFINED BBSOLVER_FIND_DEPENDENCIES)
  set(BBSOLVER_FIND_DEPENDENCIES ON)
endif()
if(NOT DEFINED BBSOLVER_USE_BUNDLED_DEPS)
  set(BBSOLVER_USE_BUNDLED_DEPS ON)
endif()
if(NOT DEFINED BBSOLVER_FORCE_BUNDLED_DEPS)
  set(BBSOLVER_FORCE_BUNDLED_DEPS OFF)
endif()

set(_BBSOLVER_THIRD_PARTY_ARCHIVE_DIR
  "${PACKAGE_PREFIX_DIR}/@BBSOLVER_INSTALL_THIRD_PARTY_ARCHIVE_DIR@")

function(_bbsolver_archive out_var archive_name)
  set(archive_path "${_BBSOLVER_THIRD_PARTY_ARCHIVE_DIR}/${archive_name}")
  if(NOT EXISTS "${archive_path}")
    set(bbsolver_FOUND FALSE PARENT_SCOPE)
    set(bbsolver_NOT_FOUND_MESSAGE
      "bbsolver dependency archive is missing: ${archive_path}"
      PARENT_SCOPE)
    return()
  endif()
  set("${out_var}" "${archive_path}" PARENT_SCOPE)
endfunction()

function(_bbsolver_ensure_nlohmann_json)
  if(TARGET nlohmann_json::nlohmann_json)
    return()
  endif()
  _bbsolver_archive(
    nlohmann_json_archive
    nlohmann-json-3.11.3.tar.xz)
  include(FetchContent)
  FetchContent_Declare(
    nlohmann_json
    URL "${nlohmann_json_archive}"
    URL_HASH SHA256=d6c65aca6b1ed68e7a182f4757257b107ae403032760ed6ef121c9d55e81757d
    DOWNLOAD_EXTRACT_TIMESTAMP TRUE)
  set(JSON_BuildTests OFF CACHE INTERNAL "")
  FetchContent_MakeAvailable(nlohmann_json)
endfunction()

function(_bbsolver_ensure_eigen)
  if(TARGET Eigen3::Eigen)
    return()
  endif()
  _bbsolver_archive(eigen_archive eigen-3.4.0.tar.gz)
  include(FetchContent)
  FetchContent_Populate(
    eigen
    URL "${eigen_archive}"
    URL_HASH SHA256=8586084f71f9bde545ee7fa6d00288b264a2b7ac3607b974e54d13e7162c1c72
    DOWNLOAD_EXTRACT_TIMESTAMP TRUE)
  file(MAKE_DIRECTORY "${eigen_BINARY_DIR}")
  file(WRITE "${eigen_BINARY_DIR}/Eigen3Config.cmake"
    "set(Eigen3_VERSION \"3.4.0\")\n"
    "if(NOT TARGET Eigen3::Eigen)\n"
    "  add_library(Eigen3::Eigen INTERFACE IMPORTED)\n"
    "  set_target_properties(Eigen3::Eigen PROPERTIES\n"
    "    INTERFACE_INCLUDE_DIRECTORIES \"${eigen_SOURCE_DIR}\")\n"
    "endif()\n"
    "set(Eigen3_FOUND TRUE)\n")
  file(WRITE "${eigen_BINARY_DIR}/Eigen3ConfigVersion.cmake"
    "set(PACKAGE_VERSION \"3.4.0\")\n"
    "if(PACKAGE_FIND_VERSION VERSION_GREATER PACKAGE_VERSION)\n"
    "  set(PACKAGE_VERSION_COMPATIBLE FALSE)\n"
    "else()\n"
    "  set(PACKAGE_VERSION_COMPATIBLE TRUE)\n"
    "endif()\n"
    "if(PACKAGE_FIND_VERSION VERSION_EQUAL PACKAGE_VERSION)\n"
    "  set(PACKAGE_VERSION_EXACT TRUE)\n"
    "endif()\n")
  set(Eigen3_DIR "${eigen_BINARY_DIR}" CACHE PATH
    "Path to bbsolver-packaged Eigen3Config.cmake" FORCE)
  if(NOT TARGET Eigen3::Eigen)
    add_library(Eigen3::Eigen INTERFACE IMPORTED)
    set_target_properties(Eigen3::Eigen PROPERTIES
      INTERFACE_INCLUDE_DIRECTORIES "${eigen_SOURCE_DIR}")
  endif()
endfunction()

function(_bbsolver_ensure_ceres)
  if(TARGET Ceres::ceres)
    return()
  endif()
  if(TARGET ceres)
    add_library(Ceres::ceres ALIAS ceres)
    return()
  endif()
  _bbsolver_ensure_eigen()
  _bbsolver_archive(ceres_archive ceres-solver-2.2.0.tar.gz)
  include(FetchContent)
  set(MINIGLOG ON CACHE BOOL "" FORCE)
  set(SUITESPARSE OFF CACHE BOOL "" FORCE)
  set(GFLAGS OFF CACHE BOOL "" FORCE)
  set(CXSPARSE OFF CACHE BOOL "" FORCE)
  set(SCHUR_SPECIALIZATIONS OFF CACHE BOOL "" FORCE)
  set(EIGENSPARSE OFF CACHE BOOL "" FORCE)
  set(BUILD_TESTING OFF CACHE BOOL "" FORCE)
  set(BUILD_EXAMPLES OFF CACHE BOOL "" FORCE)
  set(BUILD_BENCHMARKS OFF CACHE BOOL "" FORCE)
  set(PROVIDE_UNINSTALL_TARGET OFF CACHE BOOL "" FORCE)
  set(USE_CUDA OFF CACHE BOOL "" FORCE)
  FetchContent_Populate(
    ceres_solver
    URL "${ceres_archive}"
    URL_HASH SHA256=12efacfadbfdc1bbfa203c236e96f4d3c210bed96994288b3ff0c8e7c6f350d4
    DOWNLOAD_EXTRACT_TIMESTAMP TRUE)
  add_subdirectory(
    "${ceres_solver_SOURCE_DIR}"
    "${ceres_solver_BINARY_DIR}"
    EXCLUDE_FROM_ALL)
  if(TARGET Ceres::ceres)
    return()
  endif()
  if(TARGET ceres)
    add_library(Ceres::ceres ALIAS ceres)
    return()
  endif()
  set(bbsolver_FOUND FALSE PARENT_SCOPE)
  set(bbsolver_NOT_FOUND_MESSAGE
    "bbsolver could not create the Ceres::ceres dependency target"
    PARENT_SCOPE)
endfunction()

function(_bbsolver_ensure_tbb)
  if(TARGET TBB::tbb)
    return()
  endif()
  if(TARGET tbb)
    add_library(TBB::tbb ALIAS tbb)
    return()
  endif()
  _bbsolver_archive(onetbb_archive onetbb-2021.13.0.tar.gz)
  include(FetchContent)
  set(TBB_TEST OFF CACHE BOOL "" FORCE)
  set(TBB_EXAMPLES OFF CACHE BOOL "" FORCE)
  set(TBB_INSTALL OFF CACHE BOOL "" FORCE)
  set(TBB_STRICT OFF CACHE BOOL "" FORCE)
  set(TBBMALLOC_BUILD OFF CACHE BOOL "" FORCE)
  FetchContent_Populate(
    onetbb
    URL "${onetbb_archive}"
    URL_HASH SHA256=3ad5dd08954b39d113dc5b3f8a8dc6dc1fd5250032b7c491eb07aed5c94133e1
    DOWNLOAD_EXTRACT_TIMESTAMP TRUE)
  add_subdirectory(
    "${onetbb_SOURCE_DIR}"
    "${onetbb_BINARY_DIR}"
    EXCLUDE_FROM_ALL)
  if(TARGET TBB::tbb)
    return()
  endif()
  if(TARGET tbb)
    add_library(TBB::tbb ALIAS tbb)
    return()
  endif()
  set(bbsolver_FOUND FALSE PARENT_SCOPE)
  set(bbsolver_NOT_FOUND_MESSAGE
    "bbsolver could not create the TBB::tbb dependency target"
    PARENT_SCOPE)
endfunction()

function(_bbsolver_ensure_flatbuffers)
  if(TARGET flatbuffers::flatbuffers)
    return()
  endif()
  if(TARGET flatbuffers)
    add_library(flatbuffers::flatbuffers ALIAS flatbuffers)
    return()
  endif()
  _bbsolver_archive(flatbuffers_archive flatbuffers-24.3.25.tar.gz)
  include(FetchContent)
  set(FLATBUFFERS_BUILD_TESTS OFF CACHE BOOL "" FORCE)
  set(FLATBUFFERS_INSTALL OFF CACHE BOOL "" FORCE)
  set(FLATBUFFERS_BUILD_FLATC OFF CACHE BOOL "" FORCE)
  set(FLATBUFFERS_BUILD_FLATHASH OFF CACHE BOOL "" FORCE)
  set(FLATBUFFERS_BUILD_SHAREDLIB OFF CACHE BOOL "" FORCE)
  FetchContent_Declare(
    flatbuffers_src
    URL "${flatbuffers_archive}"
    URL_HASH SHA256=4157c5cacdb59737c5d627e47ac26b140e9ee28b1102f812b36068aab728c1ed
    DOWNLOAD_EXTRACT_TIMESTAMP TRUE)
  FetchContent_MakeAvailable(flatbuffers_src)
  if(TARGET flatbuffers::flatbuffers)
    return()
  endif()
  if(TARGET flatbuffers)
    add_library(flatbuffers::flatbuffers ALIAS flatbuffers)
    return()
  endif()
  set(bbsolver_FOUND FALSE PARENT_SCOPE)
  set(bbsolver_NOT_FOUND_MESSAGE
    "bbsolver could not create the flatbuffers::flatbuffers dependency target"
    PARENT_SCOPE)
endfunction()

if(BBSOLVER_FIND_DEPENDENCIES)
  if(NOT BBSOLVER_FORCE_BUNDLED_DEPS)
    find_package(nlohmann_json 3.11 QUIET NO_CMAKE_PACKAGE_REGISTRY)
    find_package(Eigen3 3.4 QUIET NO_MODULE NO_CMAKE_PACKAGE_REGISTRY)
    find_package(Ceres 2.2 QUIET NO_CMAKE_PACKAGE_REGISTRY)
    find_package(TBB 2021 QUIET COMPONENTS tbb NO_CMAKE_PACKAGE_REGISTRY)
    find_package(flatbuffers CONFIG QUIET NO_CMAKE_PACKAGE_REGISTRY)
  endif()

  if(BBSOLVER_USE_BUNDLED_DEPS)
    _bbsolver_ensure_nlohmann_json()
    _bbsolver_ensure_eigen()
    _bbsolver_ensure_ceres()
    _bbsolver_ensure_tbb()
    _bbsolver_ensure_flatbuffers()
  endif()

  if(NOT TARGET nlohmann_json::nlohmann_json)
    set(bbsolver_FOUND FALSE)
    set(bbsolver_NOT_FOUND_MESSAGE "bbsolver requires nlohmann_json::nlohmann_json")
    return()
  endif()
  if(NOT TARGET Eigen3::Eigen)
    set(bbsolver_FOUND FALSE)
    set(bbsolver_NOT_FOUND_MESSAGE "bbsolver requires Eigen3::Eigen")
    return()
  endif()
  if(NOT TARGET Ceres::ceres)
    set(bbsolver_FOUND FALSE)
    set(bbsolver_NOT_FOUND_MESSAGE "bbsolver requires Ceres::ceres")
    return()
  endif()
  if(NOT TARGET TBB::tbb)
    set(bbsolver_FOUND FALSE)
    set(bbsolver_NOT_FOUND_MESSAGE "bbsolver requires TBB::tbb")
    return()
  endif()
  if(NOT TARGET flatbuffers::flatbuffers)
    set(bbsolver_FOUND FALSE)
    set(bbsolver_NOT_FOUND_MESSAGE "bbsolver requires flatbuffers::flatbuffers")
    return()
  endif()
endif()

include("${CMAKE_CURRENT_LIST_DIR}/bbsolverTargets.cmake")

if(BBSOLVER_FIND_DEPENDENCIES AND TARGET bbsolver::core)
  target_link_libraries(bbsolver::core
    INTERFACE
      nlohmann_json::nlohmann_json
      Eigen3::Eigen
      Ceres::ceres
      TBB::tbb
      flatbuffers::flatbuffers)
endif()

check_required_components(bbsolver)
